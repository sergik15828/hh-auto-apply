# openai, anthropic, or none.
# none is useful for testing search/filtering without LLM API calls.
LLM_PROVIDER=openai

# Required by hh.ru API. Use your contact email.
HH_USER_AGENT=hh-auto-apply/1.0 (your-email@example.com)
HH_BROWSER_HEADERS=true
HH_BROWSER_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/136.0.0.0 Safari/537.36
HH_ACCEPT_LANGUAGE=ru-RU,ru;q=0.9,en-US;q=0.8,en;q=0.7
HH_API_REFERER=https://hh.ru/
HH_API_TIMEOUT_SECONDS=45
HH_API_RETRIES=3
HH_WEB_BASE=https://rostov.hh.ru
HH_BROWSER_NAV_RETRIES=3
HH_BROWSER_NAV_TIMEOUT_SECONDS=60
# Optional: use installed Google Chrome instead of bundled Playwright Chromium.
# HH_BROWSER_CHANNEL=chrome

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Where hh_login.py stores browser session state.
# Defaults to ~/.n8n-files when omitted.
N8N_FILES_DIR=

# Optional: override default config/state paths.
HH_CONFIG_PATH=my/config.yaml
HH_STATE_DB=data/hh_auto_apply.sqlite3
